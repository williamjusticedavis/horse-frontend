# ─── Backend API ─────────────────────────────────────────────────────────────
# Base URL for all api.get/post/... calls in src/lib/api.ts.
#   Dev default  → http://localhost:8000  (auto-set when VITE_API_URL is unset)
#   Prod default → ''  (same origin — API co-located with the frontend)
# Uncomment to override:
# VITE_API_URL=http://localhost:8000

# ─── App base path ────────────────────────────────────────────────────────────
# URL sub-directory the app is served from. Leave commented out for root ('/').
# Example: /template → app lives at localhost:5173/template
# VITE_BASE_PATH=/template
